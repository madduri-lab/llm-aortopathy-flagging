## Inference - Base Model ##
def validate_response_format(response_content: str) -> Optional[int]:
    """Validate response format and return prediction if valid"""
    is_recommended = re.search(r'"?testing"?\s*:\s*"?recommended"?', response_content, re.IGNORECASE)
    is_not_recommended = re.search(r'"?testing"?\s*:\s*"?not recommended"?', response_content, re.IGNORECASE)
    
    if is_recommended:
        return 1
    elif is_not_recommended:
        return 0
    return None

def get_response_with_logprobs(prompt: Dict, client, system_prompt: str, attempt: int) -> Dict:
    """Get a single response from the model with logprobs"""
    messages = [
        {"role": "system", "content": system_prompt},
        {"role": "user", "content": f"Clinical Note: {prompt['note']}"}
    ]
    
    response = client.predict(
        endpoint="meta-llama-3-1-8b-instruct",
        inputs={
            "messages": messages,
            "max_tokens": 300,
            "temperature": 0.7,
            "logprobs": True
        }
    )
    
    response_content = response['choices'][0]['message']['content'].strip()
    logprobs_content = response['choices'][0]['logprobs']['content']
    
    # Initialize probability values
    recommended_prob = None
    not_recommended_prob = None
    not_token_prob = None
    combined_prob = None
    not_token_logprob = None

    # Process logprobs and calculate probabilities
    if validate_response_format(response_content) is not None:
        print("Calculating confidence scores...")
        print("Token logprobs:")
        not_flag = False
        for item in logprobs_content:
            print(f"Token: {item['token']}, Logprob: {item['logprob']}")
            
            if 'recommended' in item['token'] and not_flag:
                not_recommended_prob = math.exp(item['logprob'])
                if 'recommended' in item['token'] and not_flag:
                    not_recommended_prob = math.exp(item['logprob'])
                    not_token_prob = math.exp(not_token_logprob)
                    combined_prob = math.exp(not_token_logprob + item['logprob'])
                    print(f"\nFinal logprobs:")
                    print(f"'not' logprob: {not_token_logprob}")
                    print(f"'recommended' logprob: {item['logprob']}")
                    print(f"Combined probability: {combined_prob:.6f}")
                break
            if 'recommended' in item['token']:
                recommended_prob = math.exp(item['logprob'])
                print(f"\nFinal logprobs:")
                print(f"'recommended' logprob: {item['logprob']}")
                print(f"Probability: {recommended_prob:.6f}")
                break
            if 'not' in item['token']:
                not_flag = True
                not_token_logprob = item['logprob']
    
    return {
        "ClinicalNoteKey": prompt['ClinicalNoteKey'],
        "id": prompt["id"],
        "label": prompt["label"],
        "tested": prompt["tested"],
        "response": response_content,
        "attempt": attempt,
        "final_probability": combined_prob if combined_prob is not None else recommended_prob
    }

def main():
    # Load JSON data
    prompts_data = prompts_data_subset
    
    # Optional: subset for testing
    #prompts_data = prompts_data[:5] + prompts_data[-10:]
    
    valid_results = []
    poorly_formatted = []
    
    for prompt in prompts_data:
        print(f"\nProcessing note ID: {prompt['ClinicalNoteKey']}")
        valid_format = False
        final_result = None
        
        # Try up to 3 times for each prompt
        for attempt in range(1, 4):
            result = get_response_with_logprobs(prompt, client, system_prompt, attempt)
            print(f"Attempt: {attempt}")
            print(f"Response: {result['response']}\n")
            
            # Check if format is valid
            if validate_response_format(result['response']) is not None:
                valid_format = True
                final_result = result
                print(f"Valid format achieved on attempt {attempt}")
                print(f"Final probability: {result['final_probability']}")
                break
            else:
                print(f"Invalid format detected on attempt {attempt}")
                if attempt < 3:
                    print("Trying again...")
        
        # After all attempts, store result in appropriate list
        if valid_format:
            valid_results.append(final_result)
            print(f"Successfully processed note ID: {prompt['ClinicalNoteKey']}")
        else:
            poorly_formatted.append(result)
            print(f"\nFailed to achieve valid format for note ID: {prompt['ClinicalNoteKey']} after 3 attempts")
            print("Original note content:")
            print("-" * 80)
            print(prompt['note'])
            print("-" * 80)

    # Save the valid results
    if valid_results:
        output_file = "/Volumes/biobank_analytics/verma_lab/llm_udd_aortopathy/output_workflow_dev/predictions_with_logprobs_and_validation.json"
        with open(output_file, "w") as file:
            json.dump(valid_results, file, indent=4)
        print(f"\nValid results saved to {output_file}")
    
    # Save the poorly formatted results
    if poorly_formatted:
        error_file = "/Volumes/biobank_analytics/verma_lab/llm_udd_aortopathy/output_workflow_dev/predictions_with_logprobs_and_validation.json"
        with open(error_file, "w") as file:
            json.dump(poorly_formatted, file, indent=4)
        print(f"Poorly formatted results saved to {error_file}")
    
    # Print summary
    print(f"\nProcessing Summary:")
    print(f"Successfully formatted: {len(valid_results)}")
    print(f"Poorly formatted: {len(poorly_formatted)}")

if __name__ == "__main__":
    main()


